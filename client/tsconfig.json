{
  "extends": "../shared/tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@findarr/shared": ["../shared/src/index.ts"],
      "@findarr/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src"]
}
