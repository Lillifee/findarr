{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug API (Backend)",
      "program": "${workspaceFolder}/api/src/index.ts",
      "runtimeArgs": ["--import", "tsx"],
      "cwd": "${workspaceFolder}/api",
      "envFile": "${workspaceFolder}/api/.env",
      "console": "integratedTerminal",
      "restart": true,
      "skipFiles": ["<node_internals>/**"],
      "outputCapture": "std",
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Debug Web (Frontend)",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/web",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${workspaceFolder}/web/src/*"
      },
      "preLaunchTask": "Start Web (Vite)",
      "serverReadyAction": {
        "pattern": "Local:.*http://localhost:5173",
        "uriFormat": "http://localhost:5173",
        "action": "openExternally"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Vitest Tests",
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": ["run", "${file}"],
      "runtimeArgs": ["--inspect-brk"],
      "cwd": "${workspaceFolder}",
      "autoAttachChildProcesses": true,
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "test",
        "VITEST_THREAD": "false"
      }
    }
  ],
  "compounds": [
    {
      "name": "Debug Full Stack (Web + API)",
      "configurations": ["Debug API (Backend)", "Debug Web (Frontend)"],
      "stopAll": true,
      "presentation": {
        "hidden": false,
        "group": "full-stack",
        "order": 1
      }
    }
  ]
}
