{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start",
      "type": "shell",
      "command": "vp run dev",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "new",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Start Client (Vite)",
      "type": "shell",
      "command": "vp dev apps/web",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE.*ready",
          "endsPattern": "Local:.*http://localhost:5173"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "Build",
      "type": "shell",
      "command": "vp run -r build",
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "vp run clean",
      "group": "build"
    },
    {
      "label": "Fix",
      "type": "shell",
      "command": "vp run fix",
      "group": "test",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "Test",
      "type": "shell",
      "command": "vp run test",
      "group": "test",
      "problemMatcher": []
    }
  ]
}
