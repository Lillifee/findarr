{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start",
			"type": "shell",
			"command": "npm run dev",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"isBackground": true,
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "new",
				"showReuseMessage": true,
				"clear": false
			}
		},
		{
			"label": "Build",
			"type": "shell",
			"command": "npm run build",
			"group": "build",
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "Clean",
			"type": "shell",
			"command": "npm run clean",
			"group": "build",
		},
		{
			"label": "Code Fix",
			"type": "shell",
			"command": "npm run code:fix",
			"group": "test",
			"problemMatcher": [
				"$tsc",
				"$eslint-stylish"
			]
		},
		{
			"label": "Test",
			"type": "shell",
			"command": "npm run test",
			"group": "test",
			"problemMatcher": [
				"$tsc",
				"$eslint-stylish"
			]
		},
	]
}