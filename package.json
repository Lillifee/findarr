{
  "name": "findarr",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:shared\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:shared": "npm run dev --workspace=@findarr/shared",
    "dev:server": "npm run dev --workspace=@findarr/server",
    "dev:client": "npm run dev --workspace=@findarr/client",
    "build": "npm run build:shared && npm run build:client && npm run build:server",
    "build:shared": "npm run build --workspace=@findarr/shared",
    "build:server": "npm run build --workspace=@findarr/server",
    "build:client": "npm run build --workspace=@findarr/client",
    "check": "npm run format:check && npm run lint:check && npm run type:check",
    "fix": "npm run format:fix && npm run lint:fix",
    "type:check": "npm run type:check --workspaces --if-present",
    "format:fix": "oxfmt",
    "format:check": "oxfmt --check",
    "lint:check": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "npm run test:run --workspaces --if-present",
    "test:update": "npm run test:run --workspaces --if-present -- -u",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:fixtures": "npm run test:fixtures --workspace=@findarr/server",
    "ci": "npm run check && npm run build && npm run test",
    "db:generate": "npm run db:generate --workspace=@findarr/server",
    "db:studio": "npm run db:studio --workspace=@findarr/server",
    "clean": "del-cli node_modules shared/dist server/dist client/dist **/*.tsbuildinfo",
    "update": "npx npm-check-updates -u --workspaces && npm install",
    "docker:build": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "docker:run": "docker compose up"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "del-cli": "^7.0.0",
    "globals": "^17.3.0",
    "npm-check-updates": "^19.3.2",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "typescript": "^5.9.3"
  }
}
