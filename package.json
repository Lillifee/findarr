{
  "name": "findarr",
  "version": "1.4.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp run --filter @findarr/shared build && vp run -r --parallel dev",
    "dev:shared": "vp run --filter @findarr/shared build",
    "dev:apps": "vp run -r --parallel dev",
    "build": "vp run -r build",
    "build:sea": "vp run -r build:sea",
    "preview": "vp run -r preview",
    "test": "vp test",
    "check": "vp check",
    "fix": "vp check --fix",
    "ci": "vp run -r build && vp check && vp test",
    "update": "vp update --latest -r",
    "db:generate": "vp run -r db:generate",
    "db:studio": "vp run -r db:studio",
    "clean": "del-cli **/node_modules **/dist **/*.tsbuildinfo",
    "docker:build": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "docker:run": "docker compose up"
  },
  "devDependencies": {
    "del-cli": "^7.0.0",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@11.12.0"
}
