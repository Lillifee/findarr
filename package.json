{
  "name": "findarr",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "preview": "pnpm -r preview",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "test": "vp test",
    "check": "pnpm format:check && pnpm lint",
    "fix": "pnpm format && pnpm lint",
    "ci": "pnpm run check && pnpm run build && pnpm run test",
    "db:generate": "pnpm -r db:generate ",
    "db:studio": "pnpm -r db:studio",
    "clean": "del-cli **/node_modules **/dist **/*.tsbuildinfo",
    "docker:build": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "docker:run": "docker compose up"
  },
  "devDependencies": {
    "del-cli": "^7.0.0",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@11.5.0"
}
