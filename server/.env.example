# TMDB API Configuration (REQUIRED)
# Get your free key from https://www.themoviedb.org/settings/api
TMDB_ACCESS_TOKEN=your_tmdb_access_token_here
TMDB_BASE_URL=https://api.themoviedb.org/3

# Trakt.tv API Configuration (OPTIONAL - for BETTER trending data)  
# Without this: Basic TMDB trending (works fine)
# With this: Enhanced social data, user behavior, better recommendations
# Get your free API key from https://trakt.tv/oauth/applications
TRAKT_CLIENT_ID=your_trakt_client_id_here

# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Authentication Configuration (REQUIRED)
# Generate a random 32+ character secret for SESSION_SECRET
# Example: openssl rand -base64 32
SESSION_SECRET=your_session_secret_here_minimum_32_characters

# Admin User Configuration (for seed script)
ADMIN_EMAIL=admin@findarr.local
ADMIN_PASSWORD=changeme
ADMIN_NAME=Admin

# Database Configuration
# Path to SQLite database file (relative to server root)
DB_PATH=./data/findarr.db