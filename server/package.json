{
  "name": "@findarr/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Fastify backend server for Findarr",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^5.0.3",
    "@findarr/shared": "*",
    "axios": "^1.13.2",
    "dotenv": "^17.2.3",
    "fastify": "^5.7.1",
    "fastify-plugin": "^5.1.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "pino-pretty": "^13.1.3",
    "rimraf": "^6.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
